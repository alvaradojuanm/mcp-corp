# Copia este archivo a .env para desarrollo local. NUNCA commitees un .env real.

# --- Identidad del servicio ---
# Nombre lógico del servicio, usado en logs y en el nombre del servidor MCP.
MCP_CORP_SERVICE_NAME=mcp-corp

# Entorno de ejecución: local | staging | production
MCP_CORP_ENVIRONMENT=local

# --- Red / transporte HTTP ---
# Host y puerto donde escucha el servidor Streamable HTTP.
MCP_CORP_HOST=0.0.0.0
MCP_CORP_PORT=8000

# --- Logging ---
# Nivel de log estándar de Python: DEBUG | INFO | WARNING | ERROR | CRITICAL
MCP_CORP_LOG_LEVEL=INFO

# --- Conector Postgres (Fase 2) ---
# En False el conector ni se instancia ni se conecta al arrancar.
MCP_CORP_POSTGRES__ENABLED=false

# Cadena de conexión libpq completa. NUNCA un valor real en este archivo ni
# en ningún commit; en local usa el Postgres de deploy/docker-compose.dev.yml.
MCP_CORP_POSTGRES__DSN=postgresql://mcp_corp:mcp_corp@localhost:5432/mcp_corp

# Pool de conexiones (psycopg_pool.AsyncConnectionPool), por réplica.
MCP_CORP_POSTGRES__MIN_POOL_SIZE=1
MCP_CORP_POSTGRES__MAX_POOL_SIZE=10
MCP_CORP_POSTGRES__POOL_OPEN_TIMEOUT_SECONDS=10.0

# Resiliencia: límite de concurrencia y timeout por operación, por réplica.
# Fórmula de capacidad: límite por réplica = techo de la fuente / nº de
# réplicas. Ver "Decisiones de diseño" en el README para el ejemplo numérico.
MCP_CORP_POSTGRES__MAX_CONCURRENCY=10
MCP_CORP_POSTGRES__ACQUIRE_TIMEOUT_SECONDS=2.0
MCP_CORP_POSTGRES__OPERATION_TIMEOUT_SECONDS=5.0

# Circuit breaker: fallos consecutivos para abrir, segundos antes de pasar a
# medio-abierto, y éxitos consecutivos en medio-abierto para volver a cerrar.
MCP_CORP_POSTGRES__CIRCUIT_FAILURE_THRESHOLD=5
MCP_CORP_POSTGRES__CIRCUIT_RESET_TIMEOUT_SECONDS=30.0
MCP_CORP_POSTGRES__CIRCUIT_SUCCESS_THRESHOLD=2

# Reservado para un futuro limitador de tasa (req/s); no aplicado todavía.
# El semáforo de arriba limita CONCURRENCIA, no TASA.
MCP_CORP_POSTGRES__RATE_LIMIT_PER_SECOND=

# --- Apagado ---
# Segundos de gracia para drenar conexiones en curso al recibir SIGTERM.
MCP_CORP_GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=10
